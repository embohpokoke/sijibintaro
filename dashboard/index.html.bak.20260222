<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIJI Bintaro - Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica', 'Arial', sans-serif;
            background: #0F0F0F;
            color: #F5F5F5;
            overflow-x: hidden;
        }

        .container {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background: #1A1A1A;
            border-right: 1px solid #333;
            padding: 2rem 0;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
        }

        .logo {
            padding: 0 1.5rem 2rem;
            font-size: 1.5rem;
            font-weight: 700;
            color: #C17E1A;
        }

        .nav-item {
            padding: 0.875rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            cursor: pointer;
            transition: all 0.2s;
            color: #AAAAAA;
            font-size: 0.95rem;
        }

        .nav-item:hover {
            background: #2A2A2A;
            color: #F5F5F5;
        }

        .nav-item.active {
            background: #2A2A2A;
            color: #C17E1A;
            border-left: 3px solid #C17E1A;
        }

        /* Main Content */
        .main-content {
            margin-left: 260px;
            flex: 1;
            padding: 2rem;
            width: calc(100% - 260px);
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }

        .header h1 {
            font-size: 1.75rem;
            font-weight: 600;
        }

        .header-right {
            display: flex;
            gap: 1rem;
            align-items: center;
            color: #AAAAAA;
            font-size: 0.9rem;
        }

        /* Cards */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .card {
            background: #1A1A1A;
            border: 1px solid #333;
            border-radius: 12px;
            padding: 1.5rem;
            transition: all 0.2s;
        }

        .card:hover {
            background: #2A2A2A;
            border-color: #444;
        }

        .card-title {
            color: #AAAAAA;
            font-size: 0.875rem;
            margin-bottom: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .card-value {
            font-size: 2rem;
            font-weight: 700;
            color: #C17E1A;
            margin-bottom: 0.5rem;
        }

        .card-change {
            font-size: 0.875rem;
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        .card-change.positive { color: #4CAF50; }
        .card-change.negative { color: #E53935; }
        .card-change.neutral { color: #777777; }

        /* Chart Container */
        .chart-container {
            background: #1A1A1A;
            border: 1px solid #333;
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .chart-title {
            font-size: 1.125rem;
            font-weight: 600;
        }

        .chart-wrapper {
            position: relative;
            height: 300px;
        }

        /* Table */
        .table-container {
            background: #1A1A1A;
            border: 1px solid #333;
            border-radius: 12px;
            padding: 1.5rem;
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            padding: 0.75rem;
            border-bottom: 2px solid #333;
            color: #AAAAAA;
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        td {
            padding: 0.875rem 0.75rem;
            border-bottom: 1px solid #2A2A2A;
        }

        tr:hover {
            background: #2A2A2A;
        }

        /* Badges */
        .badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .badge.green { background: #1B4D3E; color: #4CAF50; }
        .badge.red { background: #4D1B1B; color: #E53935; }
        .badge.orange { background: #4D3B1B; color: #FF9800; }
        .badge.blue { background: #1B2D4D; color: #2196F3; }

        /* Progress Bar */
        .progress-bar {
            width: 100%;
            height: 8px;
            background: #2A2A2A;
            border-radius: 4px;
            overflow: hidden;
            margin-top: 0.5rem;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #C17E1A, #D4A03C);
            transition: width 0.5s ease;
        }

        /* Scrollable cards */
        .orders-scroll {
            display: flex;
            gap: 1rem;
            overflow-x: auto;
            padding-bottom: 1rem;
            margin-top: 1rem;
        }

        .order-card {
            min-width: 200px;
            background: #2A2A2A;
            border: 1px solid #333;
            border-radius: 8px;
            padding: 1rem;
        }

        .order-card-id {
            font-size: 0.8rem;
            color: #777777;
            margin-bottom: 0.5rem;
        }

        .order-card-customer {
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .order-card-service {
            font-size: 0.875rem;
            color: #AAAAAA;
            margin-bottom: 0.5rem;
        }

        .order-card-amount {
            color: #C17E1A;
            font-weight: 700;
        }

        /* Page content */
        .page {
            display: none;
        }

        .page.active {
            display: block;
        }

        /* Loading */
        .loading {
            text-align: center;
            padding: 3rem;
            color: #777777;
        }

        /* Mobile */
        @media (max-width: 768px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                border-right: none;
                border-bottom: 1px solid #333;
            }

            .main-content {
                margin-left: 0;
                width: 100%;
            }

            .cards-grid {
                grid-template-columns: 1fr;
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }
        }

        /* Select dropdown */
        select {
            background: #2A2A2A;
            color: #F5F5F5;
            border: 1px solid #444;
            border-radius: 6px;
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
            cursor: pointer;
        }

        select:focus {
            outline: none;
            border-color: #C17E1A;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="logo">💛 SIJI Bintaro</div>
            <nav>
                <div class="nav-item active" data-page="dashboard">
                    <span>📊</span> Dashboard
                </div>
                <div class="nav-item" data-page="analytics">
                    <span>📈</span> Analytics
                </div>
                <div class="nav-item" data-page="orders">
                    <span>📋</span> Orders
                </div>
                <div class="nav-item" data-page="customers">
                    <span>👤</span> Customers
                </div>
                <div class="nav-item" data-page="locations">
                    <span>📍</span> Locations
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Dashboard Page -->
            <div class="page active" id="dashboard">
                <div class="header">
                    <h1>Dashboard</h1>
                    <div class="header-right">
                        <select id="dashboardMonth">
                            <option value="2026-02">Feb 2026</option>
                            <option value="2026-01">Jan 2026</option>
                            <option value="2025-12">Des 2025</option>
                        </select>
                        <span id="currentUser">siji</span>
                    </div>
                </div>

                <div class="cards-grid">
                    <div class="card">
                        <div class="card-title">Revenue</div>
                        <div class="card-value" id="dashRevenue">Rp 0</div>
                        <div class="card-change" id="dashRevenueChange">
                            <span>—</span> vs bulan lalu
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-title">Orders</div>
                        <div class="card-value" id="dashOrders">0</div>
                        <div class="card-change" id="dashOrdersChange">
                            <span>—</span> vs bulan lalu
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-title">Customers</div>
                        <div class="card-value" id="dashCustomers">0</div>
                        <div class="card-change">
                            <span id="dashNewCustomers">+0</span> baru
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-title">Target Revenue</div>
                        <div class="card-value" id="dashTarget">0%</div>
                        <div style="color: #AAAAAA; font-size: 0.875rem; margin-top: 0.5rem;">
                            <span id="dashTargetAmount">Rp 0</span> / Rp 40jt
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" id="dashTargetBar" style="width: 0%"></div>
                        </div>
                    </div>
                </div>

                <div class="chart-container">
                    <div class="chart-header">
                        <div class="chart-title">Revenue Trend - 6 Bulan Terakhir</div>
                    </div>
                    <div class="chart-wrapper">
                        <canvas id="dashboardChart"></canvas>
                    </div>
                </div>

                <div class="cards-grid" style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));">
                    <div class="card">
                        <div class="card-title">Top Layanan Bulan Ini</div>
                        <div id="topServicesTable" class="loading">Loading...</div>
                    </div>
                    <div class="card">
                        <div class="card-title">Status Pembayaran</div>
                        <div class="chart-wrapper" style="height: 200px;">
                            <canvas id="paymentChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Analytics Page -->
            <div class="page" id="analytics">
                <div class="header">
                    <h1>Analytics</h1>
                    <div class="header-right">
                        <select id="analyticsMonth">
                            <option value="2026-02">Feb 2026</option>
                            <option value="2026-01">Jan 2026</option>
                        </select>
                    </div>
                </div>

                <div class="cards-grid">
                    <div class="card">
                        <div class="card-title">Total Revenue</div>
                        <div class="card-value" id="analyticsRevenue">Rp 0</div>
                    </div>
                    <div class="card">
                        <div class="card-title">Avg Order Value</div>
                        <div class="card-value" id="analyticsAvg">Rp 0</div>
                    </div>
                    <div class="card">
                        <div class="card-title">Total Orders</div>
                        <div class="card-value" id="analyticsOrders">0</div>
                    </div>
                </div>

                <div class="chart-container">
                    <div class="chart-header">
                        <div class="chart-title">Daily Revenue</div>
                    </div>
                    <div class="chart-wrapper">
                        <canvas id="dailyChart"></canvas>
                    </div>
                </div>

                <div class="cards-grid" style="grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));">
                    <div class="chart-container">
                        <div class="chart-title">Revenue by Kategori</div>
                        <div class="chart-wrapper" style="height: 250px;">
                            <canvas id="categoryChart"></canvas>
                        </div>
                    </div>
                    <div class="chart-container">
                        <div class="chart-title">Top 5 Layanan</div>
                        <div class="chart-wrapper" style="height: 250px;">
                            <canvas id="serviceChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Orders Page -->
            <div class="page" id="orders">
                <div class="header">
                    <h1>Orders</h1>
                    <div class="header-right">
                        <select id="ordersMonth">
                            <option value="2026-02">Feb 2026</option>
                            <option value="2026-01">Jan 2026</option>
                        </select>
                        <select id="ordersStatus">
                            <option value="all">Semua Status</option>
                            <option value="Lunas">Lunas</option>
                            <option value="Belum Lunas">Belum Lunas</option>
                        </select>
                    </div>
                </div>

                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Tanggal</th>
                                <th>Customer</th>
                                <th>Layanan</th>
                                <th>Total</th>
                                <th>Pembayaran</th>
                                <th>Kasir</th>
                            </tr>
                        </thead>
                        <tbody id="ordersTable">
                            <tr><td colspan="6" class="loading">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Customers Page -->
            <div class="page" id="customers">
                <div class="header">
                    <h1>Customers</h1>
                </div>

                <div class="cards-grid">
                    <div class="card">
                        <div class="card-title">Total Customers</div>
                        <div class="card-value" id="custTotal">0</div>
                    </div>
                    <div class="card">
                        <div class="card-title">Active (60 hari)</div>
                        <div class="card-value" id="custActive">0</div>
                    </div>
                    <div class="card">
                        <div class="card-title">High Value (5+ order)</div>
                        <div class="card-value" id="custHVC">0</div>
                    </div>
                    <div class="card">
                        <div class="card-title">Churn Risk</div>
                        <div class="card-value" id="custChurn">0</div>
                    </div>
                </div>

                <div class="cards-grid" style="grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));">
                    <div class="chart-container">
                        <div class="chart-title">Order Frequency</div>
                        <div class="chart-wrapper" style="height: 250px;">
                            <canvas id="frequencyChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="table-container">
                    <div class="chart-title" style="margin-bottom: 1rem;">⭐ Top Customers</div>
                    <table>
                        <thead>
                            <tr>
                                <th>Nama</th>
                                <th>Telepon</th>
                                <th>Orders</th>
                                <th>Total Spent</th>
                                <th>Last Order</th>
                            </tr>
                        </thead>
                        <tbody id="customersTable">
                            <tr><td colspan="5" class="loading">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="table-container" style="margin-top: 2rem;">
                    <div class="chart-title" style="margin-bottom: 1rem;">⚠️ Churn Risk</div>
                    <table>
                        <thead>
                            <tr>
                                <th>Nama</th>
                                <th>Last Order</th>
                                <th>Days Since</th>
                                <th>Risk Level</th>
                            </tr>
                        </thead>
                        <tbody id="churnTable">
                            <tr><td colspan="4" class="loading">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Locations Page -->
            <div class="page" id="locations">
                <div class="header">
                    <h1>Locations</h1>
                    <div class="header-right">
                        <select id="locationsMonth">
                            <option value="2026-02">Feb 2026</option>
                            <option value="2026-01">Jan 2026</option>
                        </select>
                    </div>
                </div>

                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Location</th>
                                <th>Orders</th>
                                <th>Revenue</th>
                                <th>Customers</th>
                            </tr>
                        </thead>
                        <tbody id="locationsTable">
                            <tr><td colspan="4" class="loading">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Auth & API
        const API_BASE = '/api/dashboard';
        const AUTH_HEADER = 'Basic ' + btoa('siji:siji2026admin');

        async function apiGet(endpoint) {
            const res = await fetch(API_BASE + endpoint, {
                headers: { 'Authorization': AUTH_HEADER }
            });
            if (!res.ok) throw new Error('API error: ' + res.status);
            return res.json();
        }

        function formatRupiah(amount) {
            return 'Rp ' + Math.round(amount).toLocaleString('id-ID');
        }

        function formatDate(dateStr) {
            const d = new Date(dateStr);
            return d.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
        }

        // Navigation
        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', () => {
                const page = item.dataset.page;
                document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
                document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
                item.classList.add('active');
                document.getElementById(page).classList.add('active');
                loadPage(page);
            });
        });

        // Chart instances
        let dashChart, dailyChart, categoryChart, serviceChart, paymentChart, frequencyChart;

        // Load Dashboard
        async function loadDashboard(month = '2026-02') {
            try {
                const overview = await apiGet('/overview?month=' + month);
                const revenue = await apiGet('/revenue?period=monthly');
                const products = await apiGet('/products?month=' + month);

                // Cards
                document.getElementById('dashRevenue').textContent = formatRupiah(overview.revenue.current);
                document.getElementById('dashOrders').textContent = overview.orders.total;
                document.getElementById('dashCustomers').textContent = overview.customers.active;
                document.getElementById('dashNewCustomers').textContent = '+' + overview.customers.new;
                document.getElementById('dashTarget').textContent = overview.revenue.target_pct.toFixed(0) + '%';
                document.getElementById('dashTargetAmount').textContent = formatRupiah(overview.revenue.current);
                document.getElementById('dashTargetBar').style.width = overview.revenue.target_pct + '%';

                // Change indicators
                const revChange = document.getElementById('dashRevenueChange');
                revChange.innerHTML = `<span>${overview.revenue.change_pct > 0 ? '▲' : '▼'} ${Math.abs(overview.revenue.change_pct)}%</span> vs bulan lalu`;
                revChange.className = 'card-change ' + (overview.revenue.change_pct > 0 ? 'positive' : overview.revenue.change_pct < 0 ? 'negative' : 'neutral');

                const ordChange = document.getElementById('dashOrdersChange');
                ordChange.innerHTML = `<span>${overview.orders.change_pct > 0 ? '▲' : '▼'} ${Math.abs(overview.orders.change_pct)}%</span> vs bulan lalu`;
                ordChange.className = 'card-change ' + (overview.orders.change_pct > 0 ? 'positive' : overview.orders.change_pct < 0 ? 'negative' : 'neutral');

                // Monthly trend chart
                if (dashChart) dashChart.destroy();
                const ctx = document.getElementById('dashboardChart').getContext('2d');
                dashChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: revenue.data.map(d => d.month),
                        datasets: [{
                            label: 'Revenue',
                            data: revenue.data.map(d => d.revenue),
                            borderColor: '#C17E1A',
                            backgroundColor: 'rgba(193, 126, 26, 0.1)',
                            tension: 0.4,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: {
                                ticks: { color: '#777777', callback: (val) => formatRupiah(val) },
                                grid: { color: '#2A2A2A' }
                            },
                            x: {
                                ticks: { color: '#777777' },
                                grid: { color: '#2A2A2A' }
                            }
                        }
                    }
                });

                // Top services table
                const topHtml = products.by_service.slice(0, 5).map(s =>
                    `<div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid #2A2A2A;">
                        <span>${s.name}</span>
                        <span style="color: #C17E1A; font-weight: 600;">${formatRupiah(s.revenue)}</span>
                    </div>`
                ).join('');
                document.getElementById('topServicesTable').innerHTML = topHtml;

                // Payment status chart
                if (paymentChart) paymentChart.destroy();
                const payments = overview.orders.by_payment;
                const paymentLabels = Object.keys(payments);
                const paymentValues = Object.values(payments);
                paymentChart = new Chart(document.getElementById('paymentChart').getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: paymentLabels,
                        datasets: [{
                            data: paymentValues,
                            backgroundColor: ['#4CAF50', '#E53935', '#2196F3']
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { labels: { color: '#AAAAAA' } }
                        }
                    }
                });

            } catch (e) {
                console.error('Dashboard load error:', e);
            }
        }

        // Load Analytics
        async function loadAnalytics(month = '2026-02') {
            try {
                const overview = await apiGet('/overview?month=' + month);
                const daily = await apiGet('/revenue?period=daily&month=' + month);
                const products = await apiGet('/products?month=' + month);

                document.getElementById('analyticsRevenue').textContent = formatRupiah(overview.revenue.current);
                document.getElementById('analyticsOrders').textContent = overview.orders.total;
                const avgOrder = overview.orders.total > 0 ? overview.revenue.current / overview.orders.total : 0;
                document.getElementById('analyticsAvg').textContent = formatRupiah(avgOrder);

                // Daily chart
                if (dailyChart) dailyChart.destroy();
                dailyChart = new Chart(document.getElementById('dailyChart').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: daily.data.map(d => new Date(d.date).getDate()),
                        datasets: [{
                            label: 'Revenue Harian',
                            data: daily.data.map(d => d.revenue),
                            backgroundColor: '#C17E1A'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { ticks: { color: '#777777' }, grid: { color: '#2A2A2A' } },
                            x: { ticks: { color: '#777777' }, grid: { display: false } }
                        }
                    }
                });

                // Category chart
                if (categoryChart) categoryChart.destroy();
                categoryChart = new Chart(document.getElementById('categoryChart').getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: products.by_category.map(c => c.name),
                        datasets: [{
                            data: products.by_category.map(c => c.revenue),
                            backgroundColor: ['#C17E1A', '#2196F3', '#4CAF50', '#FF9800', '#E53935']
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { labels: { color: '#AAAAAA' } } }
                    }
                });

                // Service chart
                if (serviceChart) serviceChart.destroy();
                const top5 = products.by_service.slice(0, 5);
                serviceChart = new Chart(document.getElementById('serviceChart').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: top5.map(s => s.name),
                        datasets: [{
                            data: top5.map(s => s.revenue),
                            backgroundColor: '#C17E1A'
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { ticks: { color: '#777777' }, grid: { color: '#2A2A2A' } },
                            y: { ticks: { color: '#777777' }, grid: { display: false } }
                        }
                    }
                });

            } catch (e) {
                console.error('Analytics load error:', e);
            }
        }

        // Load Orders
        async function loadOrders(month = '2026-02', status = 'all') {
            try {
                const orders = await apiGet(`/orders?month=${month}&status=${status}&limit=100`);
                const tbody = document.getElementById('ordersTable');

                if (orders.orders.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; color:#777777;">Tidak ada data</td></tr>';
                    return;
                }

                tbody.innerHTML = orders.orders.map(o => `
                    <tr>
                        <td>${formatDate(o.date)}</td>
                        <td>${o.customer || '-'}<br><small style="color:#777777;">${o.phone || ''}</small></td>
                        <td>${o.service || o.category || '-'}</td>
                        <td style="color:#C17E1A; font-weight:600;">${formatRupiah(o.amount)}</td>
                        <td><span class="badge ${o.payment === 'Lunas' ? 'green' : 'red'}">${o.payment || '-'}</span></td>
                        <td>${o.kasir || '-'}</td>
                    </tr>
                `).join('');

            } catch (e) {
                console.error('Orders load error:', e);
            }
        }

        // Load Customers
        async function loadCustomers() {
            try {
                const summary = await apiGet('/customers');
                const hvcChurn = await apiGet('/hvc-churn');

                document.getElementById('custTotal').textContent = summary.total;
                document.getElementById('custActive').textContent = summary.active;
                document.getElementById('custHVC').textContent = hvcChurn.hvc.length;
                document.getElementById('custChurn').textContent = hvcChurn.churn_risk.filter(c => c.risk === 'High').length;

                // Frequency chart
                if (frequencyChart) frequencyChart.destroy();
                frequencyChart = new Chart(document.getElementById('frequencyChart').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: summary.frequency.map(f => f.range),
                        datasets: [{
                            data: summary.frequency.map(f => f.count),
                            backgroundColor: '#C17E1A'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { ticks: { color: '#777777' }, grid: { color: '#2A2A2A' } },
                            x: { ticks: { color: '#777777' }, grid: { display: false } }
                        }
                    }
                });

                // Top customers table
                const custTable = document.getElementById('customersTable');
                custTable.innerHTML = summary.top_customers.slice(0, 20).map(c => `
                    <tr>
                        <td>${c.name || '-'}</td>
                        <td>${c.phone || '-'}</td>
                        <td>${c.orders}</td>
                        <td style="color:#C17E1A; font-weight:600;">${formatRupiah(c.spent)}</td>
                        <td>${formatDate(c.last_order)}</td>
                    </tr>
                `).join('');

                // Churn risk table
                const churnTable = document.getElementById('churnTable');
                churnTable.innerHTML = hvcChurn.churn_risk.slice(0, 20).map(c => `
                    <tr>
                        <td>${c.name || '-'}</td>
                        <td>${formatDate(c.last_order)}</td>
                        <td>${c.days_since} hari</td>
                        <td><span class="badge ${c.risk === 'High' ? 'red' : c.risk === 'Medium' ? 'orange' : 'blue'}">${c.risk}</span></td>
                    </tr>
                `).join('');

            } catch (e) {
                console.error('Customers load error:', e);
            }
        }

        // Load Locations
        async function loadLocations(month = '2026-02') {
            try {
                const locations = await apiGet('/locations?month=' + month);
                const tbody = document.getElementById('locationsTable');

                if (locations.locations.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center; color:#777777;">Tidak ada data</td></tr>';
                    return;
                }

                tbody.innerHTML = locations.locations.map(loc => `
                    <tr>
                        <td>${loc.name || '-'}</td>
                        <td>${loc.orders}</td>
                        <td style="color:#C17E1A; font-weight:600;">${formatRupiah(loc.revenue)}</td>
                        <td>${loc.customers}</td>
                    </tr>
                `).join('');

            } catch (e) {
                console.error('Locations load error:', e);
            }
        }

        // Page loader router
        function loadPage(page) {
            const month = document.getElementById(page + 'Month')?.value || '2026-02';

            switch(page) {
                case 'dashboard':
                    loadDashboard(month);
                    break;
                case 'analytics':
                    loadAnalytics(month);
                    break;
                case 'orders':
                    const status = document.getElementById('ordersStatus').value;
                    loadOrders(month, status);
                    break;
                case 'customers':
                    loadCustomers();
                    break;
                case 'locations':
                    loadLocations(month);
                    break;
            }
        }

        // Event listeners for filters
        document.getElementById('dashboardMonth').addEventListener('change', (e) => loadDashboard(e.target.value));
        document.getElementById('analyticsMonth').addEventListener('change', (e) => loadAnalytics(e.target.value));
        document.getElementById('ordersMonth').addEventListener('change', (e) => loadOrders(e.target.value, document.getElementById('ordersStatus').value));
        document.getElementById('ordersStatus').addEventListener('change', (e) => loadOrders(document.getElementById('ordersMonth').value, e.target.value));
        document.getElementById('locationsMonth').addEventListener('change', (e) => loadLocations(e.target.value));

        // Initial load
        loadDashboard();
    </script>
</body>
</html>
