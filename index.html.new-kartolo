<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="SIJI Bintaro — Premium laundry & care specialist untuk sepatu, tas, dan pakaian. Antar jemput gratis radius 3km. Hubungi kami sekarang.">
<meta name="keywords" content="laundry bintaro, cuci sepatu bintaro, cuci tas bintaro, laundry premium bintaro, shoes cleaning bintaro">
<meta property="og:title" content="SIJI Bintaro — Premium Laundry & Care">
<meta property="og:description" content="Premium laundry & care specialist. Sepatu, tas, pakaian, bed cover. Antar jemput gratis.">
<meta property="og:image" content="https://sijibintaro.id/images/og-image.jpg">
<meta property="og:url" content="https://sijibintaro.id">
<title>SIJI Bintaro — Premium Laundry & Care</title>
<link rel="manifest" href="/manifest.json">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
/* ── TOKENS ─────────────────────────────────────── */
:root {
  --color-primary:    #1a1a2e;
  --color-accent:     #c8a96e;
  --color-accent-lt:  #f0e0c0;
  --color-surface:    #ffffff;
  --color-bg:         #f9f7f4;
  --color-text:       #1a1a2e;
  --color-muted:      #6b7080;
  --color-border:     #e8e0d4;
  --color-success:    #25d366;

  --font-sans: 'Plus Jakarta Sans', system-ui, sans-serif;
  --radius-sm: 8px;
  --radius-md: 14px;
  --radius-lg: 24px;
  --radius-xl: 40px;

  --space-xs:  8px;
  --space-sm:  16px;
  --space-md:  24px;
  --space-lg:  48px;
  --space-xl:  80px;
  --space-2xl: 120px;

  --shadow-sm: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
  --shadow-md: 0 4px 16px rgba(0,0,0,.08), 0 2px 6px rgba(0,0,0,.05);
  --shadow-lg: 0 12px 40px rgba(0,0,0,.12);

  --max-w: 1100px;
  --section-pad: var(--space-xl);
}

/* ── RESET ──────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body { font-family: var(--font-sans); background: var(--color-bg); color: var(--color-text); line-height: 1.6; }
img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }
ul { list-style: none; }

/* ── TYPOGRAPHY SCALE ───────────────────────────── */
.text-xs   { font-size: 11px; line-height: 1.4; }
.text-sm   { font-size: 13px; line-height: 1.5; }
.text-base { font-size: 15px; line-height: 1.6; }
.text-lg   { font-size: 18px; line-height: 1.5; }
.text-xl   { font-size: 22px; line-height: 1.4; }
.text-2xl  { font-size: 28px; line-height: 1.3; }
.text-3xl  { font-size: 36px; line-height: 1.2; }
.text-4xl  { font-size: 48px; line-height: 1.1; }
.text-5xl  { font-size: 60px; line-height: 1.05; }
.fw-400 { font-weight: 400; }
.fw-500 { font-weight: 500; }
.fw-600 { font-weight: 600; }
.fw-700 { font-weight: 700; }
.fw-800 { font-weight: 800; }
.text-muted   { color: var(--color-muted); }
.text-accent  { color: var(--color-accent); }
.text-center  { text-align: center; }
.text-upper   { text-transform: uppercase; letter-spacing: 1.5px; }

/* ── LAYOUT ─────────────────────────────────────── */
.container { max-width: var(--max-w); margin: 0 auto; padding: 0 var(--space-md); }
.section   { padding: var(--section-pad) 0; }
.section-alt { background: var(--color-surface); }
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); }
.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
.grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-md); }
.flex     { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.gap-sm { gap: var(--space-sm); }
.gap-md { gap: var(--space-md); }

/* ── COMPONENTS ─────────────────────────────────── */
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 14px 28px; border-radius: var(--radius-xl);
  font-family: var(--font-sans); font-size: 14px; font-weight: 700;
  cursor: pointer; border: none; transition: all 0.2s ease;
  letter-spacing: 0.3px;
}
.btn-primary {
  background: var(--color-accent); color: var(--color-primary);
  box-shadow: 0 4px 16px rgba(200,169,110,.35);
}
.btn-primary:hover { background: #d4b57a; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(200,169,110,.4); }
.btn-outline {
  background: transparent; color: var(--color-primary);
  border: 2px solid var(--color-border);
}
.btn-outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
.btn-wa {
  background: var(--color-success); color: #fff;
  box-shadow: 0 4px 16px rgba(37,211,102,.3);
}
.btn-wa:hover { background: #20c05c; transform: translateY(-1px); }
.btn-lg { padding: 18px 36px; font-size: 15px; }

.badge {
  display: inline-block; padding: 5px 12px; border-radius: 20px;
  font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;
}
.badge-accent { background: var(--color-accent-lt); color: #8a6520; }
.badge-dark   { background: var(--color-primary); color: var(--color-accent); }

.card {
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-lg); padding: var(--space-md);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}
.card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }

.icon-wrap {
  width: 52px; height: 52px; border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  font-size: 24px; flex-shrink: 0;
}
.icon-accent { background: var(--color-accent-lt); }
.icon-dark   { background: var(--color-primary); }

.divider { height: 1px; background: var(--color-border); margin: var(--space-lg) 0; }

/* ── NAVBAR ─────────────────────────────────────── */
.navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(249,247,244,.92); backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border);
  transition: all 0.3s ease;
}
.navbar .container { padding-top: 16px; padding-bottom: 16px; }
.nav-brand { font-size: 20px; font-weight: 800; color: var(--color-primary); }
.nav-brand span { color: var(--color-accent); }
.nav-links { display: flex; gap: var(--space-md); align-items: center; }
.nav-links a { font-size: 14px; font-weight: 500; color: var(--color-muted); transition: color 0.2s; }
.nav-links a:hover { color: var(--color-primary); }
.nav-cta { margin-left: var(--space-xs); }
.nav-mobile-toggle { display: none; background: none; border: none; cursor: pointer; padding: 4px; }

/* ── HERO ───────────────────────────────────────── */
.hero {
  min-height: 100vh; padding: 120px 0 80px;
  background: linear-gradient(160deg, #1a1a2e 0%, #2d2b4e 50%, #1a2a1a 100%);
  position: relative; overflow: hidden;
}
.hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 60% at 70% 30%, rgba(200,169,110,.15) 0%, transparent 70%);
}
.hero .container { position: relative; z-index: 1; }
.hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); align-items: center; }
.hero-content .badge { margin-bottom: var(--space-sm); }
.hero-headline {
  font-size: clamp(36px, 5vw, 56px); font-weight: 800;
  color: #fff; line-height: 1.1; margin: var(--space-sm) 0 var(--space-md);
}
.hero-headline em { color: var(--color-accent); font-style: normal; }
.hero-sub { font-size: 17px; color: rgba(255,255,255,.65); margin-bottom: var(--space-lg); max-width: 460px; }
.hero-actions { display: flex; gap: var(--space-sm); flex-wrap: wrap; }
.hero-stats { display: flex; gap: var(--space-lg); margin-top: var(--space-lg); }
.hero-stat-n { font-size: 28px; font-weight: 800; color: var(--color-accent); }
.hero-stat-l { font-size: 12px; color: rgba(255,255,255,.5); margin-top: 2px; }
.hero-visual {
  background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--radius-xl); padding: var(--space-lg);
  backdrop-filter: blur(8px);
}
.hero-service-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-sm); }
.hero-service-item {
  background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--radius-md); padding: var(--space-sm) var(--space-md);
  display: flex; align-items: center; gap: 10px;
}
.hero-service-item .icon { font-size: 22px; }
.hero-service-item .name { font-size: 13px; font-weight: 600; color: #fff; }
.hero-service-item .price { font-size: 11px; color: var(--color-accent); margin-top: 2px; }
.hero-badge-live {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(37,211,102,.15); border: 1px solid rgba(37,211,102,.3);
  border-radius: 20px; padding: 6px 12px; margin-bottom: var(--space-md);
  font-size: 12px; color: #4ade80; font-weight: 600;
}
.dot-live { width: 7px; height: 7px; background: #4ade80; border-radius: 50%; animation: pulse 1.5s infinite; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.4} }

/* ── TRUST BAR ──────────────────────────────────── */
.trust-bar { background: var(--color-primary); padding: var(--space-md) 0; }
.trust-bar .container { display: flex; gap: var(--space-xl); justify-content: center; flex-wrap: wrap; }
.trust-item { display: flex; align-items: center; gap: 10px; }
.trust-item .icon { font-size: 20px; }
.trust-item .text { font-size: 13px; color: rgba(255,255,255,.7); }
.trust-item .text strong { color: #fff; display: block; font-size: 14px; }

/* ── SERVICES ───────────────────────────────────── */
.service-tabs { display: flex; gap: var(--space-xs); margin-bottom: var(--space-lg); flex-wrap: wrap; }
.service-tab {
  padding: 10px 20px; border-radius: var(--radius-xl); font-size: 13px; font-weight: 600;
  cursor: pointer; border: 2px solid var(--color-border); background: transparent;
  color: var(--color-muted); transition: all 0.2s; font-family: var(--font-sans);
}
.service-tab.active, .service-tab:hover {
  border-color: var(--color-accent); color: var(--color-primary);
  background: var(--color-accent-lt);
}
.service-panel { display: none; }
.service-panel.active { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-sm); }
.price-card {
  background: var(--color-bg); border: 1px solid var(--color-border);
  border-radius: var(--radius-md); padding: var(--space-md); position: relative;
}
.price-card.featured {
  border-color: var(--color-accent); background: var(--color-surface);
  box-shadow: 0 0 0 3px rgba(200,169,110,.15);
}
.price-card .svc-name { font-size: 14px; font-weight: 700; margin-bottom: 4px; }
.price-card .svc-desc { font-size: 12px; color: var(--color-muted); margin-bottom: var(--space-sm); }
.price-card .svc-price { font-size: 20px; font-weight: 800; color: var(--color-accent); }
.price-card .svc-unit  { font-size: 11px; color: var(--color-muted); }
.price-card .svc-time  { font-size: 11px; color: var(--color-muted); margin-top: 6px; display: flex; align-items: center; gap: 4px; }
.price-card .featured-tag {
  position: absolute; top: -10px; right: 12px;
  background: var(--color-accent); color: var(--color-primary);
  font-size: 10px; font-weight: 700; padding: 3px 10px; border-radius: 10px;
  text-transform: uppercase; letter-spacing: 1px;
}

/* ── WHY SIJI ───────────────────────────────────── */
.why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-md); }
.why-item { display: flex; gap: var(--space-md); }
.why-item .icon-wrap { flex-shrink: 0; }
.why-item h3 { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
.why-item p  { font-size: 13px; color: var(--color-muted); line-height: 1.6; }

/* ── TESTIMONIALS ───────────────────────────────── */
.testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
.testimonial-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-md); }
.stars { color: #f59e0b; font-size: 14px; margin-bottom: var(--space-sm); }
.testimonial-text { font-size: 14px; color: var(--color-text); line-height: 1.7; margin-bottom: var(--space-md); font-style: italic; }
.testimonial-author { display: flex; align-items: center; gap: 10px; }
.author-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--color-accent-lt); display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: #8a6520; flex-shrink: 0; }
.author-name { font-size: 13px; font-weight: 700; }
.author-meta { font-size: 11px; color: var(--color-muted); }

/* ── AREA COVERAGE ──────────────────────────────── */
.area-grid { display: flex; flex-wrap: wrap; gap: var(--space-xs); }
.area-tag {
  background: var(--color-bg); border: 1px solid var(--color-border);
  border-radius: var(--radius-xl); padding: 6px 14px;
  font-size: 12px; font-weight: 500; color: var(--color-muted);
}
.area-tag.nearby { border-color: var(--color-accent); color: #8a6520; background: var(--color-accent-lt); }

/* ── HOW IT WORKS ───────────────────────────────── */
.steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-md); position: relative; }
.steps::before {
  content: ''; position: absolute; top: 34px; left: calc(12.5% + 10px); right: calc(12.5% + 10px);
  height: 1px; background: linear-gradient(90deg, var(--color-border) 0%, var(--color-accent) 50%, var(--color-border) 100%);
  z-index: 0;
}
.step { text-align: center; position: relative; z-index: 1; }
.step-num {
  width: 56px; height: 56px; border-radius: 50%; background: var(--color-surface);
  border: 2px solid var(--color-border); display: flex; align-items: center; justify-content: center;
  margin: 0 auto var(--space-sm); font-size: 22px;
}
.step.active .step-num { border-color: var(--color-accent); background: var(--color-accent-lt); }
.step h4 { font-size: 14px; font-weight: 700; margin-bottom: 4px; }
.step p  { font-size: 12px; color: var(--color-muted); }

/* ── CTA SECTION ────────────────────────────────── */
.cta-section {
  background: var(--color-primary);
  position: relative; overflow: hidden;
}
.cta-section::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse 50% 80% at 80% 50%, rgba(200,169,110,.12) 0%, transparent 70%);
}
.cta-inner { position: relative; z-index: 1; text-align: center; }
.cta-inner h2 { font-size: clamp(28px, 4vw, 44px); font-weight: 800; color: #fff; margin-bottom: var(--space-sm); }
.cta-inner p  { font-size: 16px; color: rgba(255,255,255,.6); margin-bottom: var(--space-lg); }
.cta-actions  { display: flex; gap: var(--space-sm); justify-content: center; flex-wrap: wrap; }

/* ── INFO BOX ───────────────────────────────────── */
.info-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
.info-box { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-lg) var(--space-md); text-align: center; }
.info-box .icon { font-size: 36px; margin-bottom: var(--space-sm); }
.info-box h3 { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
.info-box p  { font-size: 13px; color: var(--color-muted); line-height: 1.6; }

/* ── FOOTER ─────────────────────────────────────── */
footer {
  background: var(--color-primary); padding: var(--space-xl) 0 var(--space-lg);
  border-top: 1px solid rgba(255,255,255,.08);
}
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: var(--space-xl); margin-bottom: var(--space-lg); }
.footer-brand { font-size: 22px; font-weight: 800; color: #fff; margin-bottom: var(--space-sm); }
.footer-brand span { color: var(--color-accent); }
.footer-desc { font-size: 13px; color: rgba(255,255,255,.45); line-height: 1.7; max-width: 300px; }
.footer-col h4 { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--color-accent); margin-bottom: var(--space-sm); }
.footer-col ul li { margin-bottom: 8px; }
.footer-col ul li a { font-size: 13px; color: rgba(255,255,255,.5); transition: color 0.2s; }
.footer-col ul li a:hover { color: #fff; }
.footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: var(--space-md); border-top: 1px solid rgba(255,255,255,.08); }
.footer-bottom p { font-size: 12px; color: rgba(255,255,255,.3); }
.footer-social { display: flex; gap: var(--space-sm); }
.social-btn { width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); display: flex; align-items: center; justify-content: center; font-size: 16px; transition: all 0.2s; }
.social-btn:hover { background: rgba(200,169,110,.2); border-color: var(--color-accent); }

/* ── WA FLOAT ───────────────────────────────────── */
.wa-float {
  position: fixed; bottom: 24px; right: 24px; z-index: 99;
  background: var(--color-success); color: #fff;
  width: 60px; height: 60px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; box-shadow: 0 4px 20px rgba(37,211,102,.45);
  transition: all 0.2s; animation: float-in 0.5s ease 2s backwards;
}
.wa-float:hover { transform: scale(1.1); box-shadow: 0 6px 28px rgba(37,211,102,.55); }
@keyframes float-in { from{opacity:0;transform:scale(0.7)} to{opacity:1;transform:scale(1)} }

/* ── SECTION HEADER ─────────────────────────────── */
.section-header { text-align: center; margin-bottom: var(--space-lg); }
.section-header .badge { margin-bottom: var(--space-sm); }
.section-header h2 { font-size: clamp(24px, 4vw, 38px); font-weight: 800; margin-bottom: var(--space-sm); }
.section-header p  { font-size: 15px; color: var(--color-muted); max-width: 520px; margin: 0 auto; }

/* ── RESPONSIVE ─────────────────────────────────── */
@media (max-width: 900px) {
  .hero-inner { grid-template-columns: 1fr; }
  .hero-visual { display: none; }
  .grid-3, .service-panel.active, .testimonials-grid, .info-grid { grid-template-columns: 1fr 1fr; }
  .grid-4, .steps { grid-template-columns: 1fr 1fr; }
  .steps::before { display: none; }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .why-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  :root { --section-pad: 48px; }
  .grid-2, .grid-3, .service-panel.active, .testimonials-grid, .info-grid, .grid-4, .steps, .footer-grid { grid-template-columns: 1fr; }
  .hero { padding: 100px 0 60px; }
  .hero-stats { gap: var(--space-md); }
  .hero-actions { flex-direction: column; }
  .hero-actions .btn { justify-content: center; }
  .nav-links { display: none; }
  .nav-mobile-toggle { display: block; }
  .trust-bar .container { gap: var(--space-md); justify-content: flex-start; overflow-x: auto; }
  .cta-actions { flex-direction: column; align-items: center; }
  .footer-bottom { flex-direction: column; gap: var(--space-sm); text-align: center; }
}
</style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="container flex items-center justify-between">
    <a href="/" class="nav-brand">SIJI<span>.</span>Bintaro</a>
    <div class="nav-links">
      <a href="#layanan">Layanan</a>
      <a href="#tentang">Tentang</a>
      <a href="#area">Area</a>
      <a href="#kontak">Kontak</a>
      <a href="https://wa.me/6281288783088?text=Halo%20SIJI%2C%20saya%20mau%20tanya%20layanan" class="btn btn-wa nav-cta" target="_blank" rel="noopener">
        💬 Chat WA
      </a>
    </div>
    <button class="nav-mobile-toggle" aria-label="Menu">☰</button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-badge-live">
          <span class="dot-live"></span>
          Melayani sekarang · Bintaro & sekitarnya
        </div>
        <div class="badge badge-accent">Premium Laundry & Care</div>
        <h1 class="hero-headline">
          Bersih Premium,<br>
          <em>Hasil Terjamin</em>
        </h1>
        <p class="hero-sub">
          Spesialis perawatan pakaian, sepatu, dan tas branded. Antar jemput gratis, proses profesional, hasil yang membuat Anda percaya kembali.
        </p>
